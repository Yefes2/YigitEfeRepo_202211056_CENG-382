@{
    ViewData["Title"] = "Reset Password";
}

<div style="max-width:460px; margin:4rem auto;">
    <div class="gb-card">
        <h2 style="font-family:var(--font-display); font-size:1.8rem; margin-bottom:0.25rem;">
            RESET PASSWORD
        </h2>
        <p style="color:var(--gb-muted); font-size:0.875rem; margin-bottom:1.5rem;">
            Enter your new password below.
        </p>

        @if (TempData["Error"] != null)
        {
            <div class="gb-alert gb-alert--error">@TempData["Error"]</div>
        }

        <form method="post" asp-action="ResetPassword">
            @Html.AntiForgeryToken()
            <input type="hidden" name="token" value="@Context.Request.Query["token"]" />
            <input type="hidden" name="email" value="@Context.Request.Query["email"]" />

            <div class="gb-form-group">
                <label class="gb-label">New Password</label>
                <input type="password" name="password" id="passwordInput" class="gb-input"
                       placeholder="New password" required />
                <div class="gb-strength-bar-wrap">
                    <div class="gb-strength-bar" id="strengthBar"></div>
                </div>
                <span class="gb-strength-label" id="strengthLabel"></span>
            </div>

            <div class="gb-form-group">
                <label class="gb-label">Confirm Password</label>
                <input type="password" name="confirmPassword" class="gb-input"
                       placeholder="Confirm password" required />
            </div>

            <button type="submit" class="gb-btn gb-btn--primary" style="width:100%; margin-top:1rem;">
                Reset Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/password-strength.js"></script>
    <script>
        initPasswordStrength('passwordInput', 'strengthBar', 'strengthLabel');
    </script>
}