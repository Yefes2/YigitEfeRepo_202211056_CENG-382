@model GrubBytes.Models.ApplicationUser
@{
    ViewData["Title"] = "My Profile";
}

<div style="max-width:560px; margin:0 auto;">

    @if (TempData["Success"] != null)
    {
        <div class="gb-alert gb-alert--success" style="margin-bottom:1rem;">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="gb-alert gb-alert--error" style="margin-bottom:1rem;">@TempData["Error"]</div>
    }

    <!-- Profile Picture -->
    <div class="gb-card" style="margin-bottom:1rem; text-align:center; padding:2rem;">
        <div style="position:relative; display:inline-block;">
            <img id="avatarPreview"
                 src="@(string.IsNullOrEmpty(Model.ProfileImagePath) ? "/uploads/avatars/default.png" : Model.ProfileImagePath)"
                 onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2280%22 height=%2280%22><circle cx=%2240%22 cy=%2240%22 r=%2240%22 fill=%22%23FF6B35%22/><text x=%2240%22 y=%2248%22 text-anchor=%22middle%22 fill=%22white%22 font-size=%2232%22 font-family=%22Arial%22>@(Model.FullName.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "U")</text></svg>'"
                 style="width:90px; height:90px; border-radius:50%; object-fit:cover; border:3px solid var(--gb-orange);" />
        </div>
        <p style="color:var(--gb-muted); font-size:0.82rem; margin-top:0.5rem;">
            Click below to change your profile picture
        </p>
        <button type="button" onclick="document.getElementById('imageInput').click()"
                class="gb-btn gb-btn--outline" style="margin-top:0.5rem; font-size:0.82rem;">
            Choose Image
        </button>
        <input type="file" id="imageInput" accept="image/*" style="display:none;"
               onchange="loadImage(event)" />

        <!-- Cropper area -->
        <div id="cropperWrap" style="display:none; margin-top:1rem;">
            <div style="width:100%; max-width:400px; margin:0 auto; border-radius:8px; overflow:hidden; background:var(--gb-dark3);">
                <img id="cropperImg" style="max-width:100%;" />
            </div>
            <button type="button" onclick="cropImage()"
                    class="gb-btn gb-btn--primary" style="margin-top:0.75rem;">
                Crop & Save Preview
            </button>
        </div>
    </div>

    <!-- Profile Form -->
    <div class="gb-card" style="margin-bottom:1rem;">
        <h3 style="font-family:var(--font-display); font-size:1.3rem; margin-bottom:1.25rem;">
            Account Details
        </h3>
        <form asp-action="Profile" method="post" id="profileForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="croppedImage" id="croppedImageInput" />

            <div class="gb-form-group">
                <label class="gb-label">Full Name</label>
                <input type="text" name="fullName" class="gb-input" value="@Model.FullName" />
            </div>

            <div class="gb-form-group">
                <label class="gb-label">Email</label>
                <input type="text" class="gb-input" value="@Model.Email" disabled
                       style="opacity:0.5; cursor:not-allowed;" />
            </div>

            <div style="border-top:1px solid var(--gb-border); margin:1.25rem 0;"></div>

            <p style="font-family:var(--font-display); font-size:1rem; margin-bottom:1rem;">
                Change Password
            </p>

            <div class="gb-form-group">
                <label class="gb-label">Current Password</label>
                <input type="password" name="currentPassword" class="gb-input"
                       placeholder="Leave blank to keep current" />
            </div>

            <div class="gb-form-group">
                <label class="gb-label">New Password</label>
                <input type="password" name="newPassword" id="newPasswordInput" class="gb-input"
                       placeholder="Leave blank to keep current" />
                <div class="gb-strength-bar-wrap">
                    <div class="gb-strength-bar" id="strengthBar"></div>
                </div>
                <span class="gb-strength-label" id="strengthLabel"></span>
            </div>

            <button type="submit" class="gb-btn gb-btn--primary gb-btn--full"
                    style="margin-top:0.5rem;">
                Save Changes
            </button>
        </form>
    </div>

    <!-- Delete Account -->
    <div class="gb-card" style="border-color:#e74c3c44;">
        <h3 style="font-family:var(--font-display); font-size:1.3rem; color:#e74c3c; margin-bottom:0.5rem;">
            Delete Account
        </h3>
        <p style="color:var(--gb-muted); font-size:0.85rem; margin-bottom:1rem;">
            This action is permanent and cannot be undone. All your data will be deleted.
        </p>
        <button type="button" onclick="document.getElementById('deleteSection').style.display='block'"
                class="gb-btn gb-btn--outline"
                style="border-color:#e74c3c; color:#e74c3c; font-size:0.85rem;">
            I want to delete my account
        </button>
        <div id="deleteSection" style="display:none; margin-top:1rem;">
            <form asp-action="DeleteAccount" method="post">
                @Html.AntiForgeryToken()
                <div class="gb-form-group">
                    <label class="gb-label">Type your email to confirm</label>
                    <input type="email" name="confirmEmail" class="gb-input"
                           placeholder="@Model.Email" />
                </div>
                <button type="submit" class="gb-btn gb-btn--outline"
                        style="border-color:#e74c3c; color:#e74c3c; width:100%;">
                    Permanently Delete Account
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/cropperjs@1.5.13/dist/cropper.min.css" />
    <script src="https://unpkg.com/cropperjs@1.5.13/dist/cropper.min.js"></script>
    <script src="~/js/password-strength.js"></script>
    <script>
        initPasswordStrength('newPasswordInput', 'strengthBar', 'strengthLabel');

        let cropper = null;

        function loadImage(event) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function (e) {
        const img = document.getElementById('cropperImg');
        img.src = e.target.result;

        document.getElementById('cropperWrap').style.display = 'block';

        if (cropper) cropper.destroy();
        cropper = new Cropper(img, {
        aspectRatio: 1,
        viewMode: 1,
        dragMode: 'move',
        cropBoxResizable: false,
        cropBoxMovable: false,
        toggleDragModeOnDblclick: false,
        ready() {
        const box = this.cropper.getCropBoxData();
        const min = Math.min(box.width, box.height);
        this.cropper.setCropBoxData({ width: min, height: min });
        }
        });
        };
        reader.readAsDataURL(file);
        }

        function cropImage() {
        if (!cropper) return;

        const canvas = cropper.getCroppedCanvas({ width: 200, height: 200 });
        const dataUrl = canvas.toDataURL('image/jpeg', 0.85);

        document.getElementById('croppedImageInput').value = dataUrl;
        document.getElementById('avatarPreview').src = dataUrl;
        document.getElementById('cropperWrap').style.display = 'none';

        showToast('Profile picture ready. Click Save Changes to apply.', 'success');
        }
    </script>
}