@model GrubBytes.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="gb-auth-wrap">
    <div class="gb-card gb-auth-card">
        <h2 class="gb-auth-title">Welcome back</h2>
        <p class="gb-auth-sub">Sign in to GrubBytes</p>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="gb-error"></div>

            <div class="gb-form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" class="gb-input" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="gb-field-error"></span>
            </div>

            <div class="gb-form-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" class="gb-input" placeholder="••••••" />
                <span asp-validation-for="Password" class="gb-field-error"></span>
            </div>

            <div class="gb-form-group gb-form-group--row">
                <label>
                    <input asp-for="RememberMe" type="checkbox" /> Remember me
                </label>
            </div>
            <div class="g-recaptcha" data-sitekey="@ViewData["ReCaptchaSiteKey"]" style="margin-bottom:1rem;"></div>
            <button type="submit" class="gb-btn gb-btn--primary gb-btn--full">Sign In</button>
            <div style="text-align:center; margin-top:0.75rem;">
                <a asp-action="ForgotPassword" style="color:var(--gb-muted); font-size:0.875rem;">
                    Forgot your password?
                </a>
            </div>
        </form>

        <p class="gb-auth-footer">
            Don't have an account? <a asp-action="Register">Sign up</a>
        </p>
    </div>
</div>



@section Scripts {
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
}