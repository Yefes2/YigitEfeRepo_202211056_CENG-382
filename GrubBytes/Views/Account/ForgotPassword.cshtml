@{
    ViewData["Title"] = "Forgot Password";
}

<div style="max-width:460px; margin:4rem auto;">
    <div class="gb-card">
        <h2 style="font-family:var(--font-display); font-size:1.8rem; margin-bottom:0.25rem;">
            FORGOT PASSWORD
        </h2>
        <p style="color:var(--gb-muted); font-size:0.875rem; margin-bottom:1.5rem;">
            Enter your email and we'll send you a reset link.
        </p>

        @if (TempData["Success"] != null)
        {
            <div class="gb-alert gb-alert--success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="gb-alert gb-alert--error">@TempData["Error"]</div>
        }

        <form method="post" asp-action="ForgotPassword">
            @Html.AntiForgeryToken()
            <div class="gb-form-group">
                <label class="gb-label">Email Address</label>
                <input type="email" name="email" class="gb-input" placeholder="you@example.com" required />
            </div>
            <button type="submit" class="gb-btn gb-btn--primary" style="width:100%; margin-top:1rem;">
                Send Reset Link
            </button>
        </form>

        <div style="text-align:center; margin-top:1.25rem;">
            <a asp-action="Login" style="color:var(--gb-muted); font-size:0.875rem;">Back to Login</a>
        </div>
    </div>
</div>