@model List<GrubBytes.Models.Log>
@{
    ViewData["Title"] = "System Logs";
}

<div class="gb-page-header">
    <h1 class="gb-page-title">System Logs</h1>
    <a asp-action="ExportLogs" class="gb-btn gb-btn--outline">Export CSV</a>
</div>

<div class="gb-card">
    <div class="gb-filter-bar" style="margin-bottom:1.25rem;">
        <input type="text" id="searchInput" class="gb-input" placeholder="Search message..." />
        <input type="text" id="eventFilter" class="gb-input" placeholder="Filter by event type..." />
        <select id="severityFilter" class="gb-input">
            <option value="">All Severities</option>
            <option value="Info">Info</option>
            <option value="Warning">Warning</option>
            <option value="Error">Error</option>
        </select>
        <span id="resultCount" style="color:var(--gb-muted); font-size:0.875rem; align-self:center;"></span>
    </div>

    <table class="gb-table" id="logsTable">
        <thead>
            <tr>
                <th>Time</th>
                <th>Event</th>
                <th>User</th>
                <th>Message</th>
                <th>Severity</th>
            </tr>
        </thead>
        <tbody id="logsBody">
            @foreach (var log in Model)
            {
                <tr data-message="@log.Message.ToLower()"
                    data-event="@log.EventType.ToLower()"
                    data-severity="@log.Severity">
                    <td style="color:var(--gb-muted); font-size:0.8rem; white-space:nowrap;">
                        @log.CreatedAt.ToString("dd MMM HH:mm:ss")
                    </td>
                    <td>
                        <span class="gb-badge gb-badge--pending">@log.EventType</span>
                    </td>
                    <td style="font-size:0.85rem;">@(log.User?.Email ?? "System")</td>
                    <td style="font-size:0.85rem;">@log.Message</td>
                    <td>
                        <span class="gb-badge @(log.Severity == "Error" ? "gb-badge--cancelled" :
                                                                              log.Severity == "Warning" ? "gb-badge--pending" : "gb-badge--completed")">
                            @log.Severity
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div id="noResults" style="display:none; text-align:center; padding:2rem; color:var(--gb-muted);">
        No logs match your search.
    </div>

    <div class="gb-pagination" id="pagination"></div>
</div>

@section Scripts {
    <script>
        const ROWS_PER_PAGE = 15;
        let currentPage = 1;
        let filteredRows = [];

        const searchInput = document.getElementById('searchInput');
        const eventFilter = document.getElementById('eventFilter');
        const severityFilter = document.getElementById('severityFilter');
        const allRows = Array.from(document.querySelectorAll('#logsBody tr'));
        const noResults = document.getElementById('noResults');
        const resultCount = document.getElementById('resultCount');
        const pagination = document.getElementById('pagination');

        function applyFilters() {
            const search = searchInput.value.toLowerCase().trim();
            const event_ = eventFilter.value.toLowerCase().trim();
            const severity = severityFilter.value;

            filteredRows = allRows.filter(row => {
                const msgMatch = row.dataset.message.includes(search);
                const eventMatch = row.dataset.event.includes(event_);
                const severityMatch = !severity || row.dataset.severity === severity;
                return msgMatch && eventMatch && severityMatch;
            });

            currentPage = 1;
            render();
        }

        function render() {
            allRows.forEach(r => r.style.display = 'none');

            if (filteredRows.length === 0) {
                noResults.style.display = 'block';
                pagination.innerHTML = '';
                resultCount.textContent = '0 logs';
                return;
            }

            noResults.style.display = 'none';

            const totalPages = Math.ceil(filteredRows.length / ROWS_PER_PAGE);
            const start = (currentPage - 1) * ROWS_PER_PAGE;
            const end = start + ROWS_PER_PAGE;

            filteredRows.slice(start, end).forEach(r => r.style.display = '');
            resultCount.textContent = `${filteredRows.length} log${filteredRows.length !== 1 ? 's' : ''}`;

            renderPagination(totalPages);
        }

        function renderPagination(totalPages) {
            pagination.innerHTML = '';
            if (totalPages <= 1) return;

            const prev = document.createElement('button');
            prev.textContent = '←';
            prev.className = 'gb-btn gb-btn--ghost gb-pagination__btn';
            prev.disabled = currentPage === 1;
            prev.onclick = () => { currentPage--; render(); };
            pagination.appendChild(prev);

            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement('button');
                btn.textContent = i;
                btn.className = 'gb-btn gb-btn--ghost gb-pagination__btn' + (i === currentPage ? ' gb-pagination__btn--active' : '');
                btn.onclick = () => { currentPage = i; render(); };
                pagination.appendChild(btn);
            }

            const next = document.createElement('button');
            next.textContent = '→';
            next.className = 'gb-btn gb-btn--ghost gb-pagination__btn';
            next.disabled = currentPage === totalPages;
            next.onclick = () => { currentPage++; render(); };
            pagination.appendChild(next);
        }

        searchInput.addEventListener('input', applyFilters);
        eventFilter.addEventListener('input', applyFilters);
        severityFilter.addEventListener('change', applyFilters);

        applyFilters();
    </script>
}