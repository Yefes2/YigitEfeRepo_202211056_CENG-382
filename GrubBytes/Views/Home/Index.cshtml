@model IEnumerable<GrubBytes.Models.MenuItem>
@{
    ViewData["Title"] = "Home";
    var favoriteIds = ViewBag.FavoriteIds as List<int> ?? new List<int>();
}

<div class="gb-page-header">
    <h1 class="gb-page-title">Today's Menu</h1>
    <p class="gb-page-sub">Fresh from your neighborhood caterers</p>
</div>

@if (!Model.Any())
{
    <div class="gb-card" style="text-align:center; padding: 3rem;">
        <p style="color: var(--gb-muted)">No menu items available yet. Check back soon!</p>
    </div>
}
else
{
    <div class="gb-filter-bar" style="align-items:center; flex-wrap:wrap;">
        <input type="text" id="searchInput" class="gb-input" placeholder="Search menu..."
               style="max-width:220px;" />
        <select id="districtFilter" class="gb-input" style="max-width:220px;">
            <option value="">All Districts</option>
            @foreach (var district in Model.Select(m => m.Caterer?.BusinessName).Distinct().OrderBy(x => x))
            {
                <option value="@district?.ToLower()">@district</option>
            }
        </select>
        <div style="display:flex; align-items:center; gap:0.5rem;">
            <span style="color:var(--gb-muted); font-size:0.85rem; white-space:nowrap;">Price:</span>
            <input type="number" id="minPrice" class="gb-input" placeholder="Min ₺"
                   style="width:90px;" min="0" />
            <span style="color:var(--gb-muted);">—</span>
            <input type="number" id="maxPrice" class="gb-input" placeholder="Max ₺"
                   style="width:90px;" min="0" />
        </div>
        <span id="resultCount" style="color:var(--gb-muted); font-size:0.875rem; align-self:center;"></span>
    </div>

    <div class="gb-menu-grid" id="menuGrid">
        @foreach (var item in Model.OrderBy(m => m.Caterer?.BusinessName).ThenBy(m => m.Title))
        {
            var isFav = favoriteIds.Contains(item.Id);
            <div class="gb-card gb-menu-card"
                 data-title="@item.Title.ToLower()"
                 data-district="@item.Caterer?.BusinessName?.ToLower()"
                 data-price="@item.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">

                @if (!string.IsNullOrEmpty(item.ImagePath))
                {
                    <img src="@item.ImagePath" alt="@item.Title"
                         style="width:100%; height:180px; object-fit:cover;" />
                }

                <div class="gb-menu-card__body">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                        <p class="gb-menu-card__caterer">
                            <a href="/Home/CatererProfile/@item.CatererId" style="color:var(--gb-orange);">
                                @item.Caterer?.BusinessName
                            </a>
                        </p>
                        @if (User.IsInRole("User"))
                        {
                            <form asp-controller="Cart" asp-action="ToggleFavorite" method="post">
                                <input type="hidden" name="menuItemId" value="@item.Id" />
                                <button type="submit" class="gb-btn-icon"
                                        title="@(isFav ? "Remove from favorites" : "Add to favorites")">
                                    <svg width="16" height="16" viewBox="0 0 24 24"
                                         fill="@(isFav ? "var(--gb-orange)" : "none")"
                                         stroke="var(--gb-orange)" stroke-width="2"
                                         stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                    </svg>
                                </button>
                            </form>
                        }
                    </div>
                    <h3 class="gb-menu-card__title">@item.Title</h3>
                    <p class="gb-menu-card__desc">@item.Description</p>
                </div>

                <div class="gb-menu-card__footer">
                    <span class="gb-menu-card__price">₺@item.Price.ToString("0.00")</span>
                    @if (User.IsInRole("User"))
                    {
                        <form asp-controller="Cart" asp-action="AddToCart" method="post">
                            <input type="hidden" name="menuItemId" value="@item.Id" />
                            <input type="hidden" name="quantity" value="1" />
                            <button type="submit" class="gb-btn gb-btn--primary">Add to Cart</button>
                        </form>
                    }
                    else if (!User.Identity!.IsAuthenticated)
                    {
                        <a href="/Account/Login" class="gb-btn gb-btn--outline">Login to Order</a>
                    }
                </div>
            </div>
        }
    </div>

    <div id="noResults" style="display:none; text-align:center; padding:2rem; color:var(--gb-muted);">
        No items match your search.
    </div>

    <div class="gb-pagination" id="pagination"></div>
}

@section Scripts {
    <script>
        const ROWS_PER_PAGE = 15;
        let currentPage = 1;
        let filteredCards = [];

        const searchInput = document.getElementById('searchInput');
        const districtFilter = document.getElementById('districtFilter');
        const minPrice = document.getElementById('minPrice');
        const maxPrice = document.getElementById('maxPrice');
        const allCards = Array.from(document.querySelectorAll('#menuGrid .gb-menu-card'));
        const noResults = document.getElementById('noResults');
        const resultCount = document.getElementById('resultCount');
        const pagination = document.getElementById('pagination');

        function applyFilters() {
            const search = searchInput.value.toLowerCase().trim();
            const district = districtFilter.value.toLowerCase();
            const min = parseFloat(minPrice.value) || 0;
            const max = parseFloat(maxPrice.value) || Infinity;

            filteredCards = allCards.filter(card => {
                const titleMatch = card.dataset.title.includes(search);
                const districtMatch = !district || card.dataset.district.includes(district);
                const price = parseFloat(card.dataset.price);
                const priceMatch = price >= min && price <= max;
                return titleMatch && districtMatch && priceMatch;
            });

            currentPage = 1;
            render();
        }

        function render() {
            allCards.forEach(c => c.style.display = 'none');

            if (filteredCards.length === 0) {
                noResults.style.display = 'block';
                pagination.innerHTML = '';
                resultCount.textContent = '0 items';
                return;
            }

            noResults.style.display = 'none';

            const totalPages = Math.ceil(filteredCards.length / ROWS_PER_PAGE);
            const start = (currentPage - 1) * ROWS_PER_PAGE;
            const end = start + ROWS_PER_PAGE;

            filteredCards.slice(start, end).forEach(c => c.style.display = '');
            resultCount.textContent = `${filteredCards.length} item${filteredCards.length !== 1 ? 's' : ''}`;

            renderPagination(totalPages);
        }

        function renderPagination(totalPages) {
            pagination.innerHTML = '';
            if (totalPages <= 1) return;

            const prev = document.createElement('button');
            prev.textContent = '←';
            prev.className = 'gb-btn gb-btn--ghost gb-pagination__btn';
            prev.disabled = currentPage === 1;
            prev.onclick = () => { currentPage--; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); };
            pagination.appendChild(prev);

            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement('button');
                btn.textContent = i;
                btn.className = 'gb-btn gb-btn--ghost gb-pagination__btn' + (i === currentPage ? ' gb-pagination__btn--active' : '');
                btn.onclick = () => { currentPage = i; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); };
                pagination.appendChild(btn);
            }

            const next = document.createElement('button');
            next.textContent = '→';
            next.className = 'gb-btn gb-btn--ghost gb-pagination__btn';
            next.disabled = currentPage === totalPages;
            next.onclick = () => { currentPage++; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); };
            pagination.appendChild(next);
        }

        searchInput.addEventListener('input', applyFilters);
        districtFilter.addEventListener('change', applyFilters);
        minPrice.addEventListener('input', applyFilters);
        maxPrice.addEventListener('input', applyFilters);

        applyFilters();
    </script>
}