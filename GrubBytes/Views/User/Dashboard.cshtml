@{
    ViewData["Title"] = "My Dashboard";
    var favorites = ViewBag.Favorites as List<GrubBytes.Models.Favorite> ?? new();
    var recentOrders = ViewBag.RecentOrders as List<GrubBytes.Models.Order> ?? new();
}

<div class="gb-page-header">
    <h1 class="gb-page-title">My Dashboard</h1>
    <p class="gb-page-sub">Welcome back, @User.Identity?.Name</p>
</div>

<div class="gb-stat-grid">
    <div class="gb-card gb-stat-card">
        <p class="gb-stat-label">Total Orders</p>
        <p class="gb-stat-value">@(ViewBag.TotalOrders ?? "—")</p>
    </div>
    <div class="gb-card gb-stat-card">
        <p class="gb-stat-label">Total Spent</p>
        <p class="gb-stat-value" style="font-size:1.8rem;">
            ₺@(((decimal?)ViewBag.TotalSpent)?.ToString("0.00") ?? "—")
        </p>
    </div>
    <div class="gb-card gb-stat-card">
        <p class="gb-stat-label">Completed</p>
        <p class="gb-stat-value" style="color:var(--gb-green);">@(ViewBag.CompletedOrders ?? "—")</p>
    </div>
    <div class="gb-card gb-stat-card">
        <p class="gb-stat-label">Pending</p>
        <p class="gb-stat-value" style="color:var(--gb-gold);">@(ViewBag.PendingOrders ?? "—")</p>
    </div>
</div>

<!-- Recent Orders -->
<h2 style="font-family:var(--font-display); font-size:1.3rem; margin-bottom:1rem;">Recent Orders</h2>
@if (!recentOrders.Any())
{
    <div class="gb-card" style="text-align:center; padding:2rem; margin-bottom:1.5rem;">
        <p style="color:var(--gb-muted)">No orders yet.</p>
        <a href="/" class="gb-btn gb-btn--primary" style="margin-top:1rem;">Browse Menu</a>
    </div>
}
else
{
    <table class="gb-table" style="margin-bottom:1.5rem;">
        <thead>
            <tr>
                <th>Order #</th>
                <th>Caterer</th>
                <th>Total</th>
                <th>Date</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in recentOrders)
            {
                <tr>
                    <td style="font-family:var(--font-display);">#@order.Id</td>
                    <td style="font-size:0.85rem;">@order.Caterer?.BusinessName</td>
                    <td style="color:var(--gb-gold); font-family:var(--font-display);">
                        ₺@order.TotalAmount.ToString("0.00")
                    </td>
                    <td style="font-size:0.82rem; color:var(--gb-muted);">
                        @order.CreatedAt.ToString("dd MMM yyyy")
                    </td>
                    <td>
                        <span class="gb-badge @(order.Status == "Completed" ? "gb-badge--completed" : "gb-badge--pending")">
                            @order.Status
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <a asp-controller="Cart" asp-action="OrderHistory" class="gb-btn gb-btn--outline">
        View All Orders
    </a>
}

<!-- Favorites -->
<h2 style="font-family:var(--font-display); font-size:1.3rem; margin:1.5rem 0 1rem;">My Favorites</h2>
@if (!favorites.Any())
{
    <div class="gb-card" style="text-align:center; padding:2rem;">
        <p style="color:var(--gb-muted)">No favorites yet. Heart items on the menu to save them here.</p>
    </div>
}
else
{
    <div class="gb-menu-grid">
        @foreach (var fav in favorites)
        {
            <div class="gb-card gb-menu-card">
                <div class="gb-menu-card__body">
                    <p class="gb-menu-card__caterer">@fav.MenuItem?.Caterer?.BusinessName</p>
                    <h3 class="gb-menu-card__title">@fav.MenuItem?.Title</h3>
                    <p class="gb-menu-card__desc">@fav.MenuItem?.Description</p>
                </div>
                <div class="gb-menu-card__footer">
                    <span class="gb-menu-card__price">₺@fav.MenuItem?.Price.ToString("0.00")</span>
                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="menuItemId" value="@fav.MenuItem?.Id" />
                        <input type="hidden" name="quantity" value="1" />
                        <button type="submit" class="gb-btn gb-btn--primary">Add to Cart</button>
                    </form>
                </div>
            </div>
        }
    </div>
}