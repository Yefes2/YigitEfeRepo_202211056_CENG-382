@model List<GrubBytes.Models.CartItem>
@{
    ViewData["Title"] = "Your Cart";
}

<div class="gb-page-header">
    <h1 class="gb-page-title">Your Cart</h1>
</div>

@if (!Model.Any())
{
    <div class="gb-card" style="text-align:center; padding:3rem;">
        <p style="color:var(--gb-muted)">Your cart is empty.</p>
        <a href="/" class="gb-btn gb-btn--primary" style="margin-top:1rem">Browse Menu</a>
    </div>
}
else
{
    <div style="display:grid; grid-template-columns:1fr 320px; gap:1.5rem; align-items:start;">
        <div>
            @foreach (var item in Model)
            {
                <div class="gb-card" style="margin-bottom:1rem; padding:1.25rem;">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <div>
                            <p style="font-family:var(--font-display); font-size:1.2rem;">@item.Title</p>
                            <p style="color:var(--gb-gold); font-family:var(--font-display); font-size:1.1rem;">
                                ₺@item.UnitPrice.ToString("0.00")
                            </p>
                        </div>
                        <div style="display:flex; align-items:center; gap:0.75rem;">
                            <form asp-action="UpdateQuantity" method="post" style="display:flex; align-items:center; gap:0.5rem;">
                                <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                                <input type="number" name="quantity" value="@item.Quantity" min="1"
                                       class="gb-input" style="width:60px; text-align:center;" />
                                <button type="submit" class="gb-btn gb-btn--outline" style="font-size:0.78rem; padding:0.3rem 0.6rem;">
                                    Update
                                </button>
                            </form>
                            <form asp-action="Remove" method="post">
                                <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                                <button type="submit" class="gb-btn gb-btn--outline" style="font-size:0.78rem; padding:0.3rem 0.6rem; border-color:#e74c3c; color:#e74c3c;">
                                    Remove
                                </button>
                            </form>
                        </div>
                    </div>
                    <div style="margin-top:0.5rem; text-align:right; color:var(--gb-muted); font-size:0.85rem;">
                        Subtotal: <span style="color:var(--gb-gold); font-family:var(--font-display);">
                        ₺@((item.UnitPrice * item.Quantity).ToString("0.00"))
                    </span>
                </div>
            </div>
        }
    </div>

    <div class="gb-card" style="padding:1.5rem; position:sticky; top:80px;">
        <p style="font-family:var(--font-display); font-size:1.2rem; margin-bottom:1rem;">Order Summary</p>
        <div style="display:flex; justify-content:space-between; margin-bottom:0.5rem; font-size:0.9rem; color:var(--gb-muted);">
            <span>Items (@Model.Count)</span>
            <span style="color:var(--gb-text);">₺@ViewBag.Total.ToString("0.00")</span>
        </div>
        <div style="border-top:1px solid var(--gb-border); margin:1rem 0;"></div>
        <div style="display:flex; justify-content:space-between; font-family:var(--font-display); font-size:1.4rem;">
            <span>Total</span>
            <span style="color:var(--gb-orange);">₺@ViewBag.Total.ToString("0.00")</span>
        </div>
        <a asp-action="Checkout" class="gb-btn gb-btn--primary" style="width:100%; text-align:center; margin-top:1.25rem; padding:0.65rem;">
            Proceed to Checkout
        </a>
    </div>
</div>
}